<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
    <!--
      Real-hardware ros2_control configuration for G1 (no hand).
      Uses g1_hardware/G1HardwareInterface which talks to the robot via DDS.
      network_interface: network interface connected to the robot (e.g. "eth0").
      kp, kd:           position/velocity gains sent to each motor.
      weight_rate:      how fast (weight units/s) to ramp the arm SDK control weight.
    -->
    <xacro:macro name="g1_ros2_control" params="name network_interface kp:=60.0 kd:=1.5 waist_kp:=100.0 waist_kd:=2.0 weight_rate:=0.2">

        <ros2_control name="${name}" type="system">
            <hardware>
                <plugin>g1_hardware/G1HardwareInterface</plugin>
                <param name="network_interface">${network_interface}</param>
                <param name="kp">${kp}</param>
                <param name="kd">${kd}</param>
                <param name="waist_kp">${waist_kp}</param>
                <param name="waist_kd">${waist_kd}</param>
                <param name="weight_rate">${weight_rate}</param>
            </hardware>

            <!-- Left leg joints (state-only — controlled by onboard locomotion controller) -->
            <joint name="left_hip_pitch_joint">
                <state_interface name="position"/>
                <state_interface name="velocity"/>
            </joint>
            <joint name="left_hip_roll_joint">
                <state_interface name="position"/>
                <state_interface name="velocity"/>
            </joint>
            <joint name="left_hip_yaw_joint">
                <state_interface name="position"/>
                <state_interface name="velocity"/>
            </joint>
            <joint name="left_knee_joint">
                <state_interface name="position"/>
                <state_interface name="velocity"/>
            </joint>
            <joint name="left_ankle_pitch_joint">
                <state_interface name="position"/>
                <state_interface name="velocity"/>
            </joint>
            <joint name="left_ankle_roll_joint">
                <state_interface name="position"/>
                <state_interface name="velocity"/>
            </joint>

            <!-- Right leg joints (state-only) -->
            <joint name="right_hip_pitch_joint">
                <state_interface name="position"/>
                <state_interface name="velocity"/>
            </joint>
            <joint name="right_hip_roll_joint">
                <state_interface name="position"/>
                <state_interface name="velocity"/>
            </joint>
            <joint name="right_hip_yaw_joint">
                <state_interface name="position"/>
                <state_interface name="velocity"/>
            </joint>
            <joint name="right_knee_joint">
                <state_interface name="position"/>
                <state_interface name="velocity"/>
            </joint>
            <joint name="right_ankle_pitch_joint">
                <state_interface name="position"/>
                <state_interface name="velocity"/>
            </joint>
            <joint name="right_ankle_roll_joint">
                <state_interface name="position"/>
                <state_interface name="velocity"/>
            </joint>

            <!-- Waist joints (arm SDK controls waist + arms together) -->
            <joint name="waist_yaw_joint">
                <command_interface name="position"/>
                <state_interface name="position"/>
                <state_interface name="velocity"/>
            </joint>
            <joint name="waist_roll_joint">
                <command_interface name="position"/>
                <state_interface name="position"/>
                <state_interface name="velocity"/>
            </joint>
            <joint name="waist_pitch_joint">
                <command_interface name="position"/>
                <state_interface name="position"/>
                <state_interface name="velocity"/>
            </joint>

            <!-- Left arm joints -->
            <joint name="left_shoulder_pitch_joint">
                <command_interface name="position"/>
                <state_interface name="position"/>
                <state_interface name="velocity"/>
            </joint>
            <joint name="left_shoulder_roll_joint">
                <command_interface name="position"/>
                <state_interface name="position"/>
                <state_interface name="velocity"/>
            </joint>
            <joint name="left_shoulder_yaw_joint">
                <command_interface name="position"/>
                <state_interface name="position"/>
                <state_interface name="velocity"/>
            </joint>
            <joint name="left_elbow_joint">
                <command_interface name="position"/>
                <state_interface name="position"/>
                <state_interface name="velocity"/>
            </joint>
            <joint name="left_wrist_roll_joint">
                <command_interface name="position"/>
                <state_interface name="position"/>
                <state_interface name="velocity"/>
            </joint>
            <joint name="left_wrist_pitch_joint">
                <command_interface name="position"/>
                <state_interface name="position"/>
                <state_interface name="velocity"/>
            </joint>
            <joint name="left_wrist_yaw_joint">
                <command_interface name="position"/>
                <state_interface name="position"/>
                <state_interface name="velocity"/>
            </joint>

            <!-- Right arm joints -->
            <joint name="right_shoulder_pitch_joint">
                <command_interface name="position"/>
                <state_interface name="position"/>
                <state_interface name="velocity"/>
            </joint>
            <joint name="right_shoulder_roll_joint">
                <command_interface name="position"/>
                <state_interface name="position"/>
                <state_interface name="velocity"/>
            </joint>
            <joint name="right_shoulder_yaw_joint">
                <command_interface name="position"/>
                <state_interface name="position"/>
                <state_interface name="velocity"/>
            </joint>
            <joint name="right_elbow_joint">
                <command_interface name="position"/>
                <state_interface name="position"/>
                <state_interface name="velocity"/>
            </joint>
            <joint name="right_wrist_roll_joint">
                <command_interface name="position"/>
                <state_interface name="position"/>
                <state_interface name="velocity"/>
            </joint>
            <joint name="right_wrist_pitch_joint">
                <command_interface name="position"/>
                <state_interface name="position"/>
                <state_interface name="velocity"/>
            </joint>
            <joint name="right_wrist_yaw_joint">
                <command_interface name="position"/>
                <state_interface name="position"/>
                <state_interface name="velocity"/>
            </joint>

        </ros2_control>
    </xacro:macro>
</robot>
