<?xml version="1.0"?>
<!-- FTP mimic joints (thumb_3/4, index_2, middle_2, ring_2, little_2) are excluded
     from ros2_control — they are driven automatically via the URDF mimic attribute. -->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:macro name="g1_ros2_control" params="name initial_positions_file">
    <xacro:property name="initial_positions" value="${load_yaml(initial_positions_file)['initial_positions']}"/>
    <ros2_control name="${name}" type="system">
      <hardware>
        <plugin>mock_components/GenericSystem</plugin>
      </hardware>
      <!-- Left arm joints -->
      <joint name="left_shoulder_pitch_joint">
        <command_interface name="position"/>
        <state_interface name="position">
          <param name="initial_value">${initial_positions['left_shoulder_pitch_joint']}</param>
        </state_interface>
        <state_interface name="velocity"/>
      </joint>
      <joint name="left_shoulder_roll_joint">
        <command_interface name="position"/>
        <state_interface name="position">
          <param name="initial_value">${initial_positions['left_shoulder_roll_joint']}</param>
        </state_interface>
        <state_interface name="velocity"/>
      </joint>
      <joint name="left_shoulder_yaw_joint">
        <command_interface name="position"/>
        <state_interface name="position">
          <param name="initial_value">${initial_positions['left_shoulder_yaw_joint']}</param>
        </state_interface>
        <state_interface name="velocity"/>
      </joint>
      <joint name="left_elbow_joint">
        <command_interface name="position"/>
        <state_interface name="position">
          <param name="initial_value">${initial_positions['left_elbow_joint']}</param>
        </state_interface>
        <state_interface name="velocity"/>
      </joint>
      <joint name="left_wrist_roll_joint">
        <command_interface name="position"/>
        <state_interface name="position">
          <param name="initial_value">${initial_positions['left_wrist_roll_joint']}</param>
        </state_interface>
        <state_interface name="velocity"/>
      </joint>
      <joint name="left_wrist_pitch_joint">
        <command_interface name="position"/>
        <state_interface name="position">
          <param name="initial_value">${initial_positions['left_wrist_pitch_joint']}</param>
        </state_interface>
        <state_interface name="velocity"/>
      </joint>
      <joint name="left_wrist_yaw_joint">
        <command_interface name="position"/>
        <state_interface name="position">
          <param name="initial_value">${initial_positions['left_wrist_yaw_joint']}</param>
        </state_interface>
        <state_interface name="velocity"/>
      </joint>
      <!-- Right arm joints -->
      <joint name="right_shoulder_pitch_joint">
        <command_interface name="position"/>
        <state_interface name="position">
          <param name="initial_value">${initial_positions['right_shoulder_pitch_joint']}</param>
        </state_interface>
        <state_interface name="velocity"/>
      </joint>
      <joint name="right_shoulder_roll_joint">
        <command_interface name="position"/>
        <state_interface name="position">
          <param name="initial_value">${initial_positions['right_shoulder_roll_joint']}</param>
        </state_interface>
        <state_interface name="velocity"/>
      </joint>
      <joint name="right_shoulder_yaw_joint">
        <command_interface name="position"/>
        <state_interface name="position">
          <param name="initial_value">${initial_positions['right_shoulder_yaw_joint']}</param>
        </state_interface>
        <state_interface name="velocity"/>
      </joint>
      <joint name="right_elbow_joint">
        <command_interface name="position"/>
        <state_interface name="position">
          <param name="initial_value">${initial_positions['right_elbow_joint']}</param>
        </state_interface>
        <state_interface name="velocity"/>
      </joint>
      <joint name="right_wrist_roll_joint">
        <command_interface name="position"/>
        <state_interface name="position">
          <param name="initial_value">${initial_positions['right_wrist_roll_joint']}</param>
        </state_interface>
        <state_interface name="velocity"/>
      </joint>
      <joint name="right_wrist_pitch_joint">
        <command_interface name="position"/>
        <state_interface name="position">
          <param name="initial_value">${initial_positions['right_wrist_pitch_joint']}</param>
        </state_interface>
        <state_interface name="velocity"/>
      </joint>
      <joint name="right_wrist_yaw_joint">
        <command_interface name="position"/>
        <state_interface name="position">
          <param name="initial_value">${initial_positions['right_wrist_yaw_joint']}</param>
        </state_interface>
        <state_interface name="velocity"/>
      </joint>
      <!-- Left Inspire FTP hand — actuated joints only (mimic joints excluded) -->
      <joint name="left_thumb_1_joint">
        <command_interface name="position"/>
        <state_interface name="position">
          <param name="initial_value">${initial_positions['left_thumb_1_joint']}</param>
        </state_interface>
        <state_interface name="velocity"/>
      </joint>
      <joint name="left_thumb_2_joint">
        <command_interface name="position"/>
        <state_interface name="position">
          <param name="initial_value">${initial_positions['left_thumb_2_joint']}</param>
        </state_interface>
        <state_interface name="velocity"/>
      </joint>
      <joint name="left_index_1_joint">
        <command_interface name="position"/>
        <state_interface name="position">
          <param name="initial_value">${initial_positions['left_index_1_joint']}</param>
        </state_interface>
        <state_interface name="velocity"/>
      </joint>
      <joint name="left_middle_1_joint">
        <command_interface name="position"/>
        <state_interface name="position">
          <param name="initial_value">${initial_positions['left_middle_1_joint']}</param>
        </state_interface>
        <state_interface name="velocity"/>
      </joint>
      <joint name="left_ring_1_joint">
        <command_interface name="position"/>
        <state_interface name="position">
          <param name="initial_value">${initial_positions['left_ring_1_joint']}</param>
        </state_interface>
        <state_interface name="velocity"/>
      </joint>
      <joint name="left_little_1_joint">
        <command_interface name="position"/>
        <state_interface name="position">
          <param name="initial_value">${initial_positions['left_little_1_joint']}</param>
        </state_interface>
        <state_interface name="velocity"/>
      </joint>
      <!-- Right Inspire FTP hand — actuated joints only -->
      <joint name="right_thumb_1_joint">
        <command_interface name="position"/>
        <state_interface name="position">
          <param name="initial_value">${initial_positions['right_thumb_1_joint']}</param>
        </state_interface>
        <state_interface name="velocity"/>
      </joint>
      <joint name="right_thumb_2_joint">
        <command_interface name="position"/>
        <state_interface name="position">
          <param name="initial_value">${initial_positions['right_thumb_2_joint']}</param>
        </state_interface>
        <state_interface name="velocity"/>
      </joint>
      <joint name="right_index_1_joint">
        <command_interface name="position"/>
        <state_interface name="position">
          <param name="initial_value">${initial_positions['right_index_1_joint']}</param>
        </state_interface>
        <state_interface name="velocity"/>
      </joint>
      <joint name="right_middle_1_joint">
        <command_interface name="position"/>
        <state_interface name="position">
          <param name="initial_value">${initial_positions['right_middle_1_joint']}</param>
        </state_interface>
        <state_interface name="velocity"/>
      </joint>
      <joint name="right_ring_1_joint">
        <command_interface name="position"/>
        <state_interface name="position">
          <param name="initial_value">${initial_positions['right_ring_1_joint']}</param>
        </state_interface>
        <state_interface name="velocity"/>
      </joint>
      <joint name="right_little_1_joint">
        <command_interface name="position"/>
        <state_interface name="position">
          <param name="initial_value">${initial_positions['right_little_1_joint']}</param>
        </state_interface>
        <state_interface name="velocity"/>
      </joint>
    </ros2_control>
  </xacro:macro>
</robot>
